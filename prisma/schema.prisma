generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  household Household? @relation("PrimaryUser")

  householdMemberships    HouseholdMembership[]
  sentInvitations         HouseholdInvitation[]  @relation("InvitedBy")
  collaborationActivities CollaborationActivity[] @relation("ActivityActor")
  subscription            UserSubscription?
  notifications           Notification[]         @relation("UserNotifications")
  notificationPreference  NotificationPreference? @relation("UserNotificationPreference")
  passwordResetTokens     PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Household {
  id               String       @id @default(cuid())
  name             String
  primaryUserId    String       @unique
  filingStatus     FilingStatus @default(SINGLE)
  stateOfResidence String?
  planningMode     PlanningMode @default(INDIVIDUAL)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  primaryUser         User                  @relation("PrimaryUser", fields: [primaryUserId], references: [id], onDelete: Cascade)
  members             HouseholdMember[]
  incomeSources       IncomeSource[]
  assetAccounts       AssetAccount[]
  liabilities         Liability[]
  expenseProfile      ExpenseProfile?
  benefitSources      BenefitSource[]
  realEstateProperties RealEstateProperty[]
  insuranceProfile    InsuranceProfile?
  planningAssumptions PlanningAssumptions?
  simulationRuns          SimulationRun[]
  scenarios               Scenario[]
  monteCarloRuns          MonteCarloRun[]
  withdrawalStrategyRuns  WithdrawalStrategyRun[]
  socialSecurityRuns      SocialSecurityRun[]
  taxPlanningRuns         TaxPlanningRun[]
  healthcarePlanningRuns  HealthcarePlanningRun[]
  housingPlanningRuns     HousingPlanningRun[]
  memberships             HouseholdMembership[]
  invitations             HouseholdInvitation[]

  @@map("households")
}

model HouseholdMember {
  id                  String           @id @default(cuid())
  householdId         String
  firstName           String
  lastName            String
  relationshipType    RelationshipType
  dateOfBirth         DateTime
  retirementTargetAge Int
  lifeExpectancy      Int              @default(90)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  household      Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  incomeSources  IncomeSource[]
  assetAccounts  AssetAccount[]
  liabilities    Liability[]
  benefitSources BenefitSource[]

  @@map("household_members")
}

enum FilingStatus {
  SINGLE
  MARRIED_FILING_JOINTLY
  MARRIED_FILING_SEPARATELY
  HEAD_OF_HOUSEHOLD
}

enum PlanningMode {
  INDIVIDUAL
  COUPLE
}

enum RelationshipType {
  PRIMARY
  SPOUSE
  DEPENDENT
}

enum IncomeType {
  SALARY
  BONUS
  PENSION
  RENTAL
  BUSINESS
  PART_TIME
  OTHER
}

enum IncomeFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum AssetOwnerType {
  INDIVIDUAL
  JOINT
  HOUSEHOLD
}

enum AssetType {
  CHECKING
  SAVINGS
  BROKERAGE
  TRADITIONAL_401K
  ROTH_401K
  TRADITIONAL_IRA
  ROTH_IRA
  HSA
  ANNUITY
  CASH
  CD
  OTHER
}

enum AssetTaxTreatment {
  TAXABLE
  TAX_DEFERRED
  TAX_FREE
  MIXED
}

enum LiabilityType {
  MORTGAGE
  AUTO_LOAN
  STUDENT_LOAN
  CREDIT_CARD
  PERSONAL_LOAN
  HELOC
  OTHER
}

enum BenefitType {
  SOCIAL_SECURITY
  PENSION
  ANNUITY_INCOME
  VETERANS_BENEFIT
  DISABILITY
  OTHER
}

enum PropertyType {
  PRIMARY_RESIDENCE
  VACATION_HOME
  RENTAL_PROPERTY
  LAND
  OTHER
}

enum PropertyOwnershipType {
  INDIVIDUAL
  JOINT
  HOUSEHOLD
}

model IncomeSource {
  id                String          @id @default(cuid())
  householdId       String
  householdMemberId String
  type              IncomeType
  label             String
  amount            Decimal         @db.Decimal(12, 2)
  frequency         IncomeFrequency
  startDate         DateTime?
  endDate           DateTime?
  annualGrowthRate  Decimal?        @db.Decimal(5, 4)
  taxable           Boolean         @default(true)
  notes             String?         @db.Text
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  household       Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdMember HouseholdMember @relation(fields: [householdMemberId], references: [id], onDelete: Cascade)

  @@map("income_sources")
}

model AssetAccount {
  id                        String             @id @default(cuid())
  householdId               String
  householdMemberId         String?
  ownerType                 AssetOwnerType     @default(INDIVIDUAL)
  type                      AssetType
  institutionName           String?
  accountName               String
  currentBalance            Decimal            @db.Decimal(14, 2)
  annualContributionAmount  Decimal?           @db.Decimal(12, 2)
  contributionFrequency     IncomeFrequency?
  employerMatchAmount       Decimal?           @db.Decimal(12, 2)
  employerMatchPercent      Decimal?           @db.Decimal(5, 4)
  taxTreatment              AssetTaxTreatment
  expectedReturnRate        Decimal?           @db.Decimal(5, 4)
  notes                     String?            @db.Text
  isActive                  Boolean            @default(true)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdMember HouseholdMember? @relation(fields: [householdMemberId], references: [id], onDelete: SetNull)

  @@map("asset_accounts")
}

model Liability {
  id                String        @id @default(cuid())
  householdId       String
  householdMemberId String?
  type              LiabilityType
  label             String
  lenderName        String?
  currentBalance    Decimal       @db.Decimal(14, 2)
  interestRate      Decimal?      @db.Decimal(5, 4)
  monthlyPayment    Decimal?      @db.Decimal(10, 2)
  payoffDate        DateTime?
  isSecured         Boolean       @default(false)
  notes             String?       @db.Text
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdMember HouseholdMember? @relation(fields: [householdMemberId], references: [id], onDelete: SetNull)

  @@map("liabilities")
}

model ExpenseProfile {
  id                              String   @id @default(cuid())
  householdId                     String   @unique
  currentMonthlySpending          Decimal  @db.Decimal(10, 2)
  retirementMonthlyEssential      Decimal  @db.Decimal(10, 2)
  retirementMonthlyDiscretionary  Decimal  @db.Decimal(10, 2)
  healthcareMonthlyEstimate       Decimal  @db.Decimal(10, 2)
  housingMonthlyEstimate          Decimal  @db.Decimal(10, 2)
  travelMonthlyEstimate           Decimal? @db.Decimal(10, 2)
  otherMonthlyEstimate            Decimal? @db.Decimal(10, 2)
  inflationAssumption             Decimal? @db.Decimal(5, 4)
  notes                           String?  @db.Text
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("expense_profiles")
}

model BenefitSource {
  id                      String      @id @default(cuid())
  householdId             String
  householdMemberId       String
  type                    BenefitType
  label                   String
  estimatedMonthlyBenefit Decimal     @db.Decimal(10, 2)
  claimAge                Int
  startDate               DateTime?
  colaRate                Decimal?    @db.Decimal(5, 4)
  survivorEligible        Boolean?
  notes                   String?     @db.Text
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  household       Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdMember HouseholdMember @relation(fields: [householdMemberId], references: [id], onDelete: Cascade)

  @@map("benefit_sources")
}

model RealEstateProperty {
  id                         String                @id @default(cuid())
  householdId                String
  type                       PropertyType
  label                      String
  ownershipType              PropertyOwnershipType @default(JOINT)
  currentMarketValue         Decimal               @db.Decimal(14, 2)
  mortgageBalance            Decimal?              @db.Decimal(14, 2)
  monthlyMortgagePayment     Decimal?              @db.Decimal(10, 2)
  annualPropertyTax          Decimal?              @db.Decimal(10, 2)
  annualInsuranceCost        Decimal?              @db.Decimal(10, 2)
  annualMaintenanceEstimate  Decimal?              @db.Decimal(10, 2)
  isPrimaryResidence         Boolean               @default(false)
  downsizingCandidate        Boolean               @default(false)
  expectedSaleYear           Int?
  notes                      String?               @db.Text
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("real_estate_properties")
}

model InsuranceProfile {
  id                          String   @id @default(cuid())
  householdId                 String   @unique
  healthInsuranceStatus       String
  longTermCareCoverage        Boolean  @default(false)
  lifeInsuranceCoverageAmount Decimal? @db.Decimal(14, 2)
  lifeInsuranceNotes          String?  @db.Text
  disabilityCoverageFlag      Boolean  @default(false)
  umbrellaCoverageFlag        Boolean  @default(false)
  notes                       String?  @db.Text
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("insurance_profiles")
}

model PlanningAssumptions {
  id                            String   @id @default(cuid())
  householdId                   String   @unique
  inflationRate                 Decimal  @db.Decimal(5, 4) @default(0.03)
  expectedPortfolioReturn       Decimal  @db.Decimal(5, 4) @default(0.07)
  expectedPortfolioVolatility   Decimal  @db.Decimal(5, 4) @default(0.12)
  defaultRetirementAgeOverride  Int?
  longevityTargetPrimary        Int?
  longevityTargetSpouse         Int?
  assumedTaxRate                Decimal? @db.Decimal(5, 4)
  simulationCountDefault        Int?     @default(1000)
  notes                         String?  @db.Text
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("planning_assumptions")
}

model SimulationRun {
  id           String    @id @default(cuid())
  householdId  String
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  scenarioId   String?
  scenario     Scenario? @relation(fields: [scenarioId], references: [id])
  runType      String    @default("deterministic")
  label        String?
  snapshotJson Json
  outputJson   Json
  success          Boolean
  firstDepletionYear Int?
  endingBalance    Decimal  @db.Decimal(18, 2)
  endingNetWorth   Decimal  @db.Decimal(18, 2)
  totalWithdrawals Decimal  @db.Decimal(18, 2)
  totalTaxes       Decimal  @db.Decimal(18, 2)
  projectionStartYear Int
  projectionEndYear   Int
  yearsProjected      Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([householdId])
  @@map("simulation_runs")
}

model Scenario {
  id               String    @id @default(cuid())
  householdId      String
  household        Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  scenarioType     String    @default("CUSTOM")
  status           String    @default("ACTIVE")
  isBaseline       Boolean   @default(false)
  overridesJson    Json?
  sourceScenarioId String?
  simulationRuns          SimulationRun[]
  monteCarloRuns          MonteCarloRun[]
  withdrawalStrategyRuns  WithdrawalStrategyRun[]
  socialSecurityRuns      SocialSecurityRun[]
  taxPlanningRuns         TaxPlanningRun[]
  healthcarePlanningRuns  HealthcarePlanningRun[]
  housingPlanningRuns     HousingPlanningRun[]
  createdAt               DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([householdId])
  @@map("scenarios")
}

model WithdrawalStrategyRun {
  id                  String    @id @default(cuid())
  householdId         String
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  scenarioId          String?
  scenario            Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  label               String?
  strategyType        String
  orderingType        String
  configJson          Json
  snapshotJson        Json
  summaryJson         Json
  yearlyJson          Json
  success             Boolean
  firstDepletionYear  Int?
  endingAssets        Decimal   @db.Decimal(18, 2)
  totalWithdrawals    Decimal   @db.Decimal(18, 2)
  totalTaxes          Decimal   @db.Decimal(18, 2)
  isStressRun         Boolean   @default(false)
  stressPathId        String?
  projectionStartYear Int
  projectionEndYear   Int
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([householdId])
  @@map("withdrawal_strategy_runs")
}

model MonteCarloRun {
  id                  String    @id @default(cuid())
  householdId         String
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  scenarioId          String?
  scenario            Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  label               String?
  seed                Int
  simulationCount     Int
  engineVersion       String    @default("1.0.0")
  assumptionsJson     Json
  snapshotJson        Json
  aggregationJson     Json
  successProbability  Decimal   @db.Decimal(5, 4)
  failureProbability  Decimal   @db.Decimal(5, 4)
  medianEndingAssets  Decimal   @db.Decimal(18, 2)
  p10EndingAssets     Decimal   @db.Decimal(18, 2)
  p90EndingAssets     Decimal   @db.Decimal(18, 2)
  medianDepletionYear Int?
  projectionStartYear Int
  projectionEndYear   Int
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([householdId])
  @@map("monte_carlo_runs")
}

model SocialSecurityRun {
  id                   String    @id @default(cuid())
  householdId          String
  household            Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  scenarioId           String?
  scenario             Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  label                String?
  inputJson            Json
  resultJson           Json
  totalLifetimeBenefit Decimal   @db.Decimal(18, 2)
  breakEvenAge         Int?
  projectionStartYear  Int
  projectionEndYear    Int
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([householdId])
  @@map("social_security_runs")
}

model TaxPlanningRun {
  id                  String    @id @default(cuid())
  householdId         String
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  scenarioId          String?
  scenario            Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  label               String?
  taxConfigJson       Json
  snapshotJson        Json
  summaryJson         Json
  yearlyJson          Json
  totalFederalTax     Decimal   @db.Decimal(18, 2)
  totalStateTax       Decimal   @db.Decimal(18, 2)
  totalLifetimeTax    Decimal   @db.Decimal(18, 2)
  firstDepletionYear  Int?
  success             Boolean
  projectionStartYear Int
  projectionEndYear   Int
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([householdId])
  @@map("tax_planning_runs")
}

model HealthcarePlanningRun {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  householdId  String
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  scenarioId   String?
  scenario     Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  label        String

  healthcareConfigJson Json
  summaryJson          Json
  yearlyJson           Json

  // Denormalized for queries
  totalHealthcareCost  Float
  endingAssets         Float
  success              Boolean
  firstDepletionYear   Int?
  hasLtcStress         Boolean @default(false)
  hasLongevityStress   Boolean @default(false)
  longevityTargetAge   Int?
  projectionStartYear  Int
  projectionEndYear    Int

  @@index([householdId])
  @@index([scenarioId])
  @@map("healthcare_planning_runs")
}

model HousingPlanningRun {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  scenarioId  String?
  scenario    Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  label       String
  strategy    String    // 'stay_in_place' | 'downsize' | 'relocate' | 'rent'

  housingConfigJson Json
  summaryJson       Json
  yearlyJson        Json
  equityReleaseJson Json?
  legacyJson        Json?

  // Denormalized for queries
  netReleasedEquity     Float
  endingFinancialAssets Float
  projectedNetEstate    Float
  success               Boolean
  firstDepletionYear    Int?
  hasDownsizing         Boolean @default(false)
  hasRelocation         Boolean @default(false)
  projectionStartYear   Int
  projectionEndYear     Int

  @@index([householdId])
  @@index([scenarioId])
  @@map("housing_planning_runs")
}

model ConversationSession {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  householdId String
  userId      String

  messagesJson Json     @default("[]")
  contextJson  Json     @default("{}")

  @@index([householdId])
  @@index([userId])
  @@map("conversation_sessions")
}

model AiInsightCache {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  generatedAt  DateTime @default(now())

  cacheKey     String   @unique
  householdId  String
  runId        String
  insightType  String
  promptVersion String
  provider     String

  inputJson    Json
  outputJson   Json

  @@index([householdId])
  @@index([runId])
  @@map("ai_insight_cache")
}

model HouseholdMembership {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  householdId     String
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  role            String    // HouseholdRole
  permissionLevel String    // PermissionLevel
  status          String    @default("ACTIVE") // MembershipStatus

  invitedByUserId String?
  invitedAt       DateTime?
  acceptedAt      DateTime?

  @@unique([householdId, userId])
  @@index([userId])
  @@index([householdId])
  @@map("household_memberships")
}

model HouseholdInvitation {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  householdId     String
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  email           String
  role            String    // HouseholdRole
  permissionLevel String    // PermissionLevel
  token           String    @unique
  status          String    @default("PENDING") // InvitationStatus

  invitedByUserId String
  invitedBy       User      @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  expiresAt       DateTime
  acceptedAt      DateTime?

  @@index([householdId])
  @@index([email])
  @@map("household_invitations")
}

model CollaborationActivity {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  householdId   String
  actorUserId   String
  actor         User     @relation("ActivityActor", fields: [actorUserId], references: [id])

  action        String   // CollaborationAction
  targetUserId  String?
  targetEmail   String?
  details       String?

  @@index([householdId])
  @@index([actorUserId])
  @@map("collaboration_activities")
}

model UserSubscription {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  householdId           String?

  stripeCustomerId      String?  @unique
  stripeSubscriptionId  String?  @unique

  planType              String   @default("FREE")   // PlanType
  status                String   @default("FREE")   // SubscriptionStatus

  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean  @default(false)

  @@index([stripeCustomerId])
  @@map("user_subscriptions")
}

// ─── Phase 18: Notifications ──────────────────────────────────────────────────

model Notification {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())

  userId      String
  user        User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  householdId String?

  type        String    // NotificationType
  title       String
  body        String    @db.Text
  metadataJson Json     @default("{}")

  isRead      Boolean   @default(false)
  readAt      DateTime?

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id          String   @id @default(cuid())
  updatedAt   DateTime @updatedAt

  userId      String   @unique
  user        User     @relation("UserNotificationPreference", fields: [userId], references: [id], onDelete: Cascade)

  emailDigest         Boolean @default(true)
  digestFrequency     String  @default("WEEKLY") // DigestFrequency
  planRiskAlerts      Boolean @default(true)
  collaborationAlerts Boolean @default(true)
  billingAlerts       Boolean @default(true)
  simulationAlerts    Boolean @default(false)

  @@map("notification_preferences")
}

model ContactRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  email     String
  subject   String?
  message   String   @db.Text

  ipAddress String?
  userAgent String?

  @@index([email])
  @@map("contact_requests")
}
