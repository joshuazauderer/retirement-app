# App
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Auth.js
AUTH_SECRET=                  # Required: random secret for Auth.js (run: openssl rand -base64 32)
AUTH_URL=https://yourdomain.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/retirement_app

# AI Provider (Phase 13)
AI_PROVIDER=openai            # openai or anthropic
AI_MODEL=gpt-4o-mini          # Model to use
OPENAI_API_KEY=               # Required if AI_PROVIDER=openai
ANTHROPIC_API_KEY=            # Required if AI_PROVIDER=anthropic

# Logging (Phase 16)
LOG_LEVEL=info                # debug | info | warn | error

# Stripe Billing (Phase 17)
STRIPE_SECRET_KEY=sk_test_...         # Stripe secret key
STRIPE_PUBLISHABLE_KEY=pk_test_...    # Stripe publishable key (for future client use)
STRIPE_WEBHOOK_SECRET=whsec_...       # Webhook endpoint secret from Stripe dashboard
STRIPE_PRO_PRICE_ID=price_...         # Stripe Price ID for Pro monthly plan
STRIPE_ADVISOR_PRICE_ID=price_...     # Stripe Price ID for Advisor monthly plan

# Security (optional overrides)
# Rate limits are configured in src/server/security/rateLimitService.ts
